// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS GLOBAIS ---

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  SALES
  LEADS
}

enum CampaignStatus {
  DRAFT
  GENERATING_STRATEGY
  WAITING_APPROVAL
  GENERATING_ASSETS
  COMPLETED
  PUBLISHED
}

enum AdPlatform {
  META
  GOOGLE
  LINKEDIN
}

// --- MODELS DE USUÁRIO E ORGANIZAÇÃO ---

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Auditoria: Soft Delete

  workspaces WorkspaceMember[]
  aiLogs     AiLog[]

  @@map("users")
}

model Workspace {
  id          String  @id @default(uuid())
  name        String // Nome interno do Workspace
  description String?

  // --- BRAND DNA (Novo) ---
  brandName    String? // Nome da Marca para a IA usar nos textos
  brandVoice   String? // ex: "Corporativo", "Jovial", "Agressivo"
  brandColors  String[] // Array de Strings: ["#FF0000", "#000000"]
  brandLogoUrl String?  @db.Text
  brandWebsite String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members      WorkspaceMember[]
  campaigns    Campaign[]
  aiLogs       AiLog[]
  integrations Integration[]

  // Adicione este campo se formos implementar o sistema de créditos do Card 3 depois
  credits Int @default(10000)

  @@map("workspaces")
}

// Procure pelo model WorkspaceMember e adicione a linha abaixo:

model WorkspaceMember {
  id   String @id @default(uuid())
  role Role   @default(MEMBER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // 👇 ADICIONE ESTA LINHA 👇
  deletedAt DateTime?

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// --- MODELS PRINCIPAIS ---

model Campaign {
  id        String            @id @default(uuid())
  name      String
  objective CampaignObjective
  platform  AdPlatform        @default(META)

  // --- Estratégia / Público ---
  targetAudience String? @db.Text
  keyBenefits    String? @db.Text
  brandTone      String?

  status      CampaignStatus @default(DRAFT)
  description String?        @db.Text

  // --- Produto ---
  productName          String?
  productCategory      String?
  productPrice         Float?
  productOriginalPrice Float?   // Para calcular % de desconto
  productUrl           String? @db.Text
  productUsp           String? @db.Text  // Unique Selling Proposition

  // --- Oferta (gatilho de conversão) ---
  offerType     String?   // "DISCOUNT" | "FREE_SHIPPING" | "BONUS" | "GUARANTEE"
  offerDeadline DateTime?
  ctaText       String?   // ex: "Compre Agora", "Garanta a Oferta"

  // --- Orçamento ---
  budgetDaily Float?
  budgetTotal Float?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Auditoria: Soft Delete

  adCreatives AdCreative[]

  @@index([workspaceId])
  @@index([deletedAt])
  @@map("campaigns")
}

model AdCreative {
  id   String @id @default(uuid())
  name String

  imageUrl String? @db.Text
  videoUrl String? @db.Text

  headline    String? @db.Text
  primaryText String? @db.Text

  aiModel    String?
  isSelected Boolean @default(false)

  facebookAdId String?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Auditoria: Soft Delete

  @@index([campaignId])
  @@index([deletedAt])
  @@map("ad_creatives")
}

// --- LOGS E INTEGRAÇÕES ---

model AiLog {
  id          String @id @default(uuid())
  workspaceId String
  userId      String

  provider String
  model    String
  type     String

  inputTokens  Int
  outputTokens Int
  totalTokens  Int

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@map("ai_logs")
}

model Integration {
  id          String @id @default(uuid())
  workspaceId String

  provider   String
  externalId String
  name       String

  accessToken  String  @db.Text
  refreshToken String? @db.Text

  status String @default("ACTIVE")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Auditoria: Soft Delete

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, externalId])
  @@index([deletedAt])
  @@map("integrations")
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String   // ex: "CAMPAIGN", "USER"
  entityId    String   // ID do registro afetado
  action      String   // "CREATE", "UPDATE", "DELETE"
  
  oldData     Json?    // Estado anterior (antes do update/delete)
  newData     Json?    // Novo estado (após create/update)
  
  workspaceId String
  userId      String   // Ator da ação
  
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([workspaceId])
  @@index([userId])
  @@map("audit_logs")
}
